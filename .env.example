# Shared
APP_ENV=development
LOG_LEVEL=info

# Frontend
WEB_PORT=2000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_MARKET_DATA_BASE_URL=http://localhost:8101
NEXT_PUBLIC_MARKET_WS_URL=ws://localhost:8000/ws/market
NEXT_PUBLIC_MARKET_WS_RECONNECT_MS=1000
NEXT_PUBLIC_MARKET_WS_MAX_RECONNECT_MS=15000

# API
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+asyncpg://trader:trader@postgres:5432/trading_framework
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:2000
BINANCE_WS_BASE_URL=wss://data-stream.binance.vision/ws
MARKET_STREAM_RECONNECT_SECONDS=1
MARKET_STREAM_MAX_RECONNECT_SECONDS=30
OANDA_REALTIME_POLL_SECONDS=2
MARKET_WS_HEARTBEAT_SECONDS=10
MARKET_WS_STALE_SECONDS=30

# Single-user MVP identity. Replace with authentication before multi-user deployment.
MVP_USER_MODE=true
MVP_USER_EMAIL=local@trading-framework.test
MVP_USER_DISPLAY_NAME=Local Trader
MVP_WATCHLIST_NAME=Main

# Safety switches
ENABLE_LIVE_TRADING=false
ENABLE_EXCHANGE_WRITES=false
DEFAULT_TRADING_MODE=paper

# Exchange adapters are read-only by default.
# Add credentials only when implementing read-only market/account data flows.
EXCHANGE_ADAPTER_MODE=read_only
BINANCE_API_KEY=
BINANCE_API_SECRET=
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice
COINBASE_API_KEY=
COINBASE_API_SECRET=

# Alerts
ALERT_EMAIL_FROM=
ALERT_WEBHOOK_URL=
